  "private": true,
  "type": "module",
  "files": [
    "packages/connector-installer-core/index.mjs",
    "packages/connector-installer-cli/index.mjs",
    "schemas/connector-index.schema.json",
    "schemas/scope-catalog.schema.json",
    "scope-catalog.json"
  ],
  "exports": {
    "./installer-core": "./packages/connector-installer-core/index.mjs"
  },
  "bin": {
    "connector-installer": "./packages/connector-installer-cli/index.mjs"
  },
  "dependencies": {
    "sigstore": "^4.1.0"
  },
  "scripts": {
    "connector-index:generate": "node ./scripts/generate-connector-index.mjs",
