{
  "name": "LinkedIn Profile",
  "version": "1.0.0",
  "scope": "linkedin.profile",
  "dialect": "json",
  "description": "LinkedIn profile including name, headline, location, about, connections count, and profile picture",
  "schema": {
    "type": "object",
    "properties": {
      "profileUrl": { "type": "string" },
      "fullName": { "type": "string" },
      "headline": { "type": "string" },
      "location": { "type": "string" },
      "connections": { "type": "string" },
      "profilePictureUrl": { "type": "string" },
      "about": { "type": "string" }
    },
    "required": ["profileUrl", "fullName", "headline", "location", "connections", "profilePictureUrl", "about"],
    "additionalProperties": false
  }
}
