# Data Connector Credentials
# Pattern: USER_LOGIN_<PLATFORM_UPPER> and USER_PASSWORD_<PLATFORM_UPPER>
# These are read by connector scripts for automated login — never sent externally.

# USER_LOGIN_INSTAGRAM=your_username
# USER_PASSWORD_INSTAGRAM=your_password

# USER_LOGIN_TWITTER=user@example.com
# USER_PASSWORD_TWITTER=your_password

# USER_LOGIN_REDDIT=your_username
# USER_PASSWORD_REDDIT=your_password

# USER_LOGIN_LINKEDIN=user@example.com
# USER_PASSWORD_LINKEDIN=your_password
