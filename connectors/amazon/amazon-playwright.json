{
  "manifest_version": "1.0",
  "connector_id": "amazon-playwright",
  "source_id": "amazon",
  "version": "1.0.0",
  "name": "Amazon",
  "company": "Amazon",
  "description": "Exports your Amazon order history and profile information.",
  "runtime": "playwright",
  "page_api_version": 1,
  "connect_url": "https://www.amazon.com",
  "connect_selector": "#nav-link-accountList span.nav-line-1",
  "icon": "icons/amazon.svg",
  "scopes": [
    {
      "scope": "amazon.profile",
      "label": "Your Amazon profile",
      "description": "Account name and Prime membership status"
    },
    {
      "scope": "amazon.orders",
      "label": "Your Amazon orders",
      "description": "Order history including items, prices, dates, and delivery status"
    }
  ],
  "id": "amazon-playwright",
  "connectURL": "https://www.amazon.com",
  "connectSelector": "#nav-link-accountList span.nav-line-1",
  "iconURL": "icons/amazon.svg",
  "exportFrequency": "weekly",
  "vectorize_config": {
    "documents": "orders"
  }
}
