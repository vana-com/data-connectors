        "validity": "protocol_violation",
        "classification": {
          "outcome": "failure",
          "errorClass": "protocol_violation"
        }
      }
    },
    {
      "id": "empty-but-present-payload-success",
      "fixture": "fixtures/empty-but-present-payload-success.result.json",
