{
  "manifest_version": "1.0",
  "connector_id": "tinder-playwright",
  "source_id": "tinder",
  "version": "1.0.0",
  "name": "Tinder",
  "company": "Tinder",
  "description": "Exports your Tinder profile, matches, and messages using Playwright browser automation.",
  "runtime": "playwright",
  "page_api_version": 1,
  "connect_url": "https://tinder.com",
  "connect_selector": "[data-testid='profileCard'], a[href*='/app/'], a[href*='/app/recs']",
  "icon": "icons/tinder.svg",
  "scopes": [
    {
      "scope": "tinder.profile",
      "label": "Your Profile",
      "description": "Your Tinder profile including name, bio, photos, age, and preferences."
    },
    {
      "scope": "tinder.matches",
      "label": "Your Matches",
      "description": "Your match history with names, match dates, and profile info."
    },
    {
      "scope": "tinder.messages",
      "label": "Your Messages",
      "description": "Conversation history with your matches."
    }
  ],
  "id": "tinder-playwright",
  "connectURL": "https://tinder.com",
  "connectSelector": "[data-testid='profileCard'], a[href*='/app/'], a[href*='/app/recs']",
  "iconURL": "icons/tinder.svg",
  "exportFrequency": "weekly",
  "vectorize_config": {
    "documents": "messages"
  }
}
