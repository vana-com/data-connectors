{
  "manifest_version": "1.0",
  "connector_id": "shop-playwright",
  "source_id": "shop",
  "version": "1.0.0",
  "name": "Shop",
  "company": "Shopify",
  "description": "Exports your Shop app order history.",
  "runtime": "playwright",
  "page_api_version": 1,
  "connect_url": "https://shop.app/account/order-history",
  "connect_selector": "main h1, main h2, [data-test*=\"order\"], [data-testid*=\"order\"]",
  "icon": "icons/shop.svg",
  "consumer_metadata": {
    "display_name": "Shop",
    "brand_domain": "shop.app",
    "aliases": ["shopify"],
    "icon_key": "shop",
    "default_scope": "shop.orders"
  },
  "scopes": [
    {
      "scope": "shop.orders",
      "label": "Your Order History",
      "description": "Complete order history from the Shop app including merchants, items, totals, and delivery status"
    }
  ],
  "id": "shop-playwright",
  "connectURL": "https://shop.app/account/order-history",
  "connectSelector": "main h1, main h2, [data-test*=\"order\"], [data-testid*=\"order\"]",
  "iconURL": "icons/shop.svg",
  "exportFrequency": "weekly",
  "vectorize_config": {
    "documents": "orders"
  }
}
