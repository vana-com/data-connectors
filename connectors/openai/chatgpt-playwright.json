{
  "manifest_version": "1.0",
  "connector_id": "chatgpt-playwright",
  "source_id": "chatgpt",
  "version": "2.0.0",
  "name": "ChatGPT",
  "company": "OpenAI",
  "description": "Exports your email, memories, and all conversations from ChatGPT.",
  "runtime": "playwright",
  "page_api_version": 1,
  "connect_url": "https://chatgpt.com/",
  "connect_selector": "nav a[href^='/c/']",
  "icon": "icons/chatgpt.svg",
  "consumer_metadata": {
    "display_name": "ChatGPT",
    "brand_domain": "chatgpt.com",
    "aliases": ["openai"],
    "icon_key": "chatgpt",
    "default_scope": "chatgpt.conversations"
  },
  "scopes": [
    {
      "scope": "chatgpt.memories",
      "label": "Your ChatGPT memories",
      "description": "Saved memories that ChatGPT uses to personalize responses"
    },
    {
      "scope": "chatgpt.conversations",
      "label": "Your ChatGPT conversations",
      "description": "All conversation history including messages with ChatGPT"
    }
  ],
  "id": "chatgpt-playwright",
  "connectURL": "https://chatgpt.com/",
  "connectSelector": "nav a[href^='/c/']",
  "iconURL": "icons/chatgpt.svg",
  "exportFrequency": "daily",
  "vectorize_config": {
    "documents": "content"
  }
}
