{
  "name": "iCloud Notes",
  "version": "1.0.0",
  "scope": "icloud_notes.notes",
  "dialect": "json",
  "description": "Notes exported from iCloud, including title, body text, timestamps, and parent folder reference.",
  "schema": {
    "type": "object",
    "properties": {
      "notes": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "title": { "type": "string" },
            "body": { "type": "string" },
            "folder_id": { "type": ["string", "null"] },
            "folder_name": { "type": ["string", "null"] },
            "created_at": { "type": ["string", "null"] },
            "modified_at": { "type": ["string", "null"] }
          },
          "required": ["id", "title"],
          "additionalProperties": false
        }
      },
      "total": { "type": "number" }
    },
    "required": ["notes"],
    "additionalProperties": false
  }
}
